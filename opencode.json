{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".opencode/rules/*.md"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "cwd": "."
    }
  },
  "command": {
    "test": { "description": "Run all Playwright tests", "template": "npx playwright test" },
    "typecheck": { "description": "TypeScript type-check", "template": "npx tsc --noEmit" },
    "test-file": { "description": "Run a single test file (usage: /test-file <path>)", "template": "npx playwright test ${input}" },
    "test-ui": { "description": "Open Playwright UI mode", "template": "npx playwright test --ui" },
    "flaky": { "description": "Re-run last flaky test 3x with trace (usage: /flaky <spec>)", "template": "npx playwright test --repeat-each=3 --trace=on ${input}" },
    "flaky-analyze": { "description": "Show flaky test patterns from last run (usage: /flaky-analyze)", "template": "npx playwright show-trace test-results/.last-failed/trace.zip" },
    "tc": { "description": "Generate automation test from TC file. Usage: /tc AT-B-E2E-001", "template": "echo Processing ${input}..." },
    "test-api": { "description": "Run API tests only (no browser)", "template": "npx playwright test --project=api" }
  }
}
