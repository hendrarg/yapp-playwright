{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".opencode/rules/*.md"
  ],
  "command": {
    "test": { "description": "Run all Playwright tests", "template": "npx playwright test" },
    "typecheck": { "description": "TypeScript type-check", "template": "npx tsc --noEmit" },
    "test-file": { "description": "Run a single test file (usage: /test-file <path>)", "template": "npx playwright test ${input}" },
    "test-ui": { "description": "Open Playwright UI mode", "template": "npx playwright test --ui" }
  }
}
